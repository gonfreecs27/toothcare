RewriteEngine On

# Prevent directory listing (IMPORTANT)
Options -Indexes

# Disable MultiViews (prevents weird auto-matching)
Options -MultiViews

# Redirect .php URLs to clean URLs (SEO friendly)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# Internally serve .php files without showing extension
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# Return 404 if accessing a directory without index file
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.php !-f
RewriteCond %{REQUEST_FILENAME}/index.html !-f
RewriteRule ^ - [R=404,L]

# Custom 404 page
ErrorDocument 404 /404.php