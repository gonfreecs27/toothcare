RewriteEngine On

# =========================
# 1. ALLOW ONLY ROOT + PUBLIC
# =========================

# Allow root (index.php) and /public
RewriteCond %{REQUEST_URI} !^/toothcare/?$
RewriteCond %{REQUEST_URI} !^/toothcare/public/
RewriteRule ^ - [R=404,L]

# =========================
# 2. PREVENT DIRECTORY LISTING
# =========================
Options -Indexes
Options -MultiViews

# =========================
# 3. HANDLE ROOT INDEX ONLY
# =========================
DirectoryIndex index.php

# =========================
# 4. CLEAN URL SUPPORT (ONLY INSIDE /public)
# =========================
RewriteCond %{REQUEST_URI} ^/toothcare/public/
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^public/(.+?)/?$ public/$1.php [L]

# Redirect .php inside public to clean URL
RewriteCond %{THE_REQUEST} \s/+toothcare/public/(.+?)\.php[\s?] [NC]
RewriteRule ^public/(.+)\.php$ public/$1 [R=301,L]

# =========================
# 5. BLOCK DIRECT ACCESS TO INTERNAL STRUCTURE
# =========================
RewriteRule ^(app|models|configs|schema)(/|$) - [R=404,L]

# =========================
# 6. ROOT 404 HANDLER
# =========================
ErrorDocument 404 /toothcare/public/404.php